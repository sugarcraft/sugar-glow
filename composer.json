{
    "name": "candycore/sugar-glow",
    "description": "PHP port of charmbracelet/glow — Markdown CLI viewer composing CandyShine + Viewport.",
    "type": "library",
    "license": "MIT",
    "bin": ["bin/sugarglow"],
    "require": {
        "php": "^8.1",
        "candycore/candy-core":  "@dev",
        "candycore/candy-shine": "@dev",
        "candycore/sugar-bits":  "@dev",
        "symfony/console":       "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-shine",     "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-bits",      "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Glow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Glow\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
